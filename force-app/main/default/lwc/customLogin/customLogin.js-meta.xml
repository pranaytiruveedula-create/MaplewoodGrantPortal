<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Custom Login</masterLabel>
    <description>Custom login component with password visibility toggle</description>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="forgotPasswordUrl" type="String" default="/ForgotPassword" label="Forgot Password URL"/>
            <property name="selfRegisterUrl" type="String" default="/SelfRegister" label="Self Register URL"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
