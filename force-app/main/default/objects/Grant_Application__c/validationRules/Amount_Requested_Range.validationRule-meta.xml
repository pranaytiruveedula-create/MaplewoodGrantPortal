<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Amount_Requested_Range</fullName>
    <active>true</active>
    <description>Amount Requested must be between $100 and $50,000</description>
    <errorConditionFormula>OR(
    Amount_Requested__c &lt; 100,
    Amount_Requested__c &gt; 50000
)</errorConditionFormula>
    <errorDisplayField>Amount_Requested__c</errorDisplayField>
    <errorMessage>Amount Requested must be between $100 and $50,000</errorMessage>
</ValidationRule>
